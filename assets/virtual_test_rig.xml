<mujoco model="Virtual Tire Test Rig">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.001" integrator="implicit" cone="elliptic"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4" width="512" height="512" mark="cross" markrgb="0.8 0.8 0.8"/>
        <material name="grid" texture="grid" texrepeat="5 5" texuniform="true"/>
    </asset>

    <default>
        <!-- We use velocity actuators to strictly enforce translation and spin for slip sweeps -->
        <motor ctrllimited="true" ctrlrange="-1000 1000"/>
        <velocity ctrllimited="true" ctrlrange="-100 100" kv="1000"/>
        <position ctrllimited="true" ctrlrange="-180 180" kp="1000"/>
    </default>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <geom name="floor" type="plane" size="0 0 0.05" material="grid" friction="1 0.005 0.0001"/>

        <!-- Carriage that translates over the floor -->
        <body name="carriage" pos="0 0 0.35">
            <!-- X and Y translation -->
            <joint name="translate_x" type="slide" axis="1 0 0" frictionloss="0.1"/>
            <joint name="translate_y" type="slide" axis="0 1 0" frictionloss="0.1"/>
            <!-- Z translation for vertical load -->
            <joint name="translate_z" type="slide" axis="0 0 1" frictionloss="0.1"/>
            
            <geom type="box" size="0.1 0.1 0.05" rgba="0.8 0.2 0.2 1" mass="50"/>

            <!-- Camber adjustment link -->
            <body name="camber_link" pos="0 0 0">
                <inertial pos="0 0 0" mass="1" diaginertia="0.01 0.01 0.01"/>
                <joint name="camber" type="hinge" axis="1 0 0" frictionloss="0.1"/>
                
                <!-- Steering/Yaw adjustment link -->
                <body name="steer_link" pos="0 0 0">
                    <inertial pos="0 0 0" mass="1" diaginertia="0.01 0.01 0.01"/>
                    <joint name="steer" type="hinge" axis="0 0 1" frictionloss="0.1"/>
                    
                    <!-- The actual Wheel -->
                    <body name="wheel" pos="0 0 0">
                        <!-- Y-axis corresponds to rolling -->
                        <joint name="spin" type="hinge" axis="0 1 0" frictionloss="0.1"/>
                        <geom name="tire" type="cylinder" size="0.3 0.1" rgba="0.1 0.1 0.1 1" mass="15" friction="1 0.005 0.0001"/>
                        <!-- The site where Pacejka forces will eventually be applied -->
                        <site name="contact_patch" pos="0 0 -0.3" size="0.02" rgba="1 0 0 1"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <!-- Velocity control to enforce Vx and Vy -->
        <velocity name="drive_x" joint="translate_x" kv="1000"/>
        <velocity name="drive_y" joint="translate_y" kv="1000"/>
        
        <!-- Force control for Fz (downward force) -->
        <motor name="load_z" joint="translate_z"/>
        
        <!-- Position control for camber and slip angle (steer) -->
        <position name="set_camber" joint="camber" kp="1000"/>
        <position name="set_steer" joint="steer" kp="1000"/>
        
        <!-- Velocity control to enforce wheel spin (Omega) -->
        <velocity name="drive_spin" joint="spin" kv="1000"/>
    </actuator>

    <sensor>
        <!-- Measure forces at the translational and spin joints to see what the built-in contact does -->
        <jointpos joint="translate_z"/>
        <jointvel joint="translate_x"/>
        <jointvel joint="spin"/>
    </sensor>
</mujoco>
